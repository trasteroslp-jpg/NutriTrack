// Reglas de seguridad para Firestore
// Pega esto en Firebase Console > Firestore > Reglas

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas para usuarios y sus datos privados
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Subcolección de comidas
      match /meals/{mealId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Otras subcolecciones (extra/health, etc.)
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
